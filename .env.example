# =============================================================================
# Local secrets — NOT committed to Git. Copy this file to `.env` and fill in.
#
#   cp .env.example .env
#
# Two API keys are required for the documented Docker workflow:
#   - ANTHROPIC_API_KEY  → Agent memo (Claude)
#   - ALPHA_VANTAGE_API_KEY → MSFT/SPY monthly prices and beta during ingestion
# =============================================================================

# Claude (Agent page, POST /agent/run)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Alpha Vantage (ingestion: spot price and 5Y monthly beta vs SPY)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Cached model JSON demo (GET /model/msft/demo) — set to 1 only when using demo file
# ASSIDUOS_DEMO=1

# CORS — defaults match localhost Docker; override if your origin differs
# FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
