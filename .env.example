# =============================================================================
# Local secrets — NOT committed to Git. Copy this file to `.env` and fill in.
#
#   cp .env.example .env
#
# Then edit `.env` with your own keys (Anthropic required for the Agent page).
# =============================================================================

# --- Required for Agent (Claude memo) ---
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Optional (recommended if Yahoo rate-limits during ingest) ---
# Free tier: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# --- Optional demo mode ---
# ASSIDUOS_DEMO=1

# --- Optional CORS (defaults are usually fine for localhost) ---
# FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
